# =============================================================================
# XenoSys Environment Configuration
# =============================================================================
# Copy this file to .env and configure your settings
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
DEBUG=false

# -----------------------------------------------------------------------------
# Network Binding (Security)
# -----------------------------------------------------------------------------
# Set TAURI_ENV=true in Desktop mode to bind to 127.0.0.1 (secure)
# Leave unset or false in Docker/VPS mode to bind to 0.0.0.0
TAURI_ENV=false

# HTTP server host (only used when TAURI_ENV=false)
HOST=0.0.0.0

# gRPC server host (only used when TAURI_ENV=false)
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
# Option A: Cloud (OpenAI)
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o

# Option B: Cloud (Anthropic)
# ANTHROPIC_API_KEY=your-anthropic-key-here
# ANTHROPIC_MODEL=claude-3-opus-20240229

# Option C: Local (Ollama)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.1:8b

# -----------------------------------------------------------------------------
# Memory Integrations
# -----------------------------------------------------------------------------
# Cortex (Semantic Memory)
CORTEX_ENDPOINT=http://cortex:8000
CORTEX_API_KEY=

# OpenViking (Episodic Memory)
OPENVIKING_ENDPOINT=http://openviking:8080
OPENVIKING_API_KEY=

# Obsidian MCP (2ndBrain - Long-term Memory)
OBSIDIAN_MCP_URL=http://mcp-obsidian:3000/sse

# BrainSys MCP (Contextual Memory)
BRAINSYS_MCP_URL=http://mcp-brainsys:9000/sse

# -----------------------------------------------------------------------------
# Messaging
# -----------------------------------------------------------------------------
MESSAGE_BROKER=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------------
GATEWAY_PORT=3000
GRPC_PORT=50051
JWT_SECRET=your-super-secret-jwt-key-change-in-production
HMAC_SECRET=your-hmac-secret-key-change-in-production

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
# Telemetry endpoint (optional)
TELEMETRY_ENDPOINT=