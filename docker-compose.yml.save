# =============================================================================
# XenoSys Docker Compose Configuration (V1.0.0-RC-PROD)
# =============================================================================

services:
  # -------------------------------------------------------------------------
  # 1. Gateway Service (Node.js)
  # -------------------------------------------------------------------------
  gateway:
    build:
      context: ./nexus/gateway
    container_name: xenosys-gateway
    ports:
      - "3000:3000"
    environment:
      - NODE_ENV=production
      - HOST=0.0.0.0
      - REDIS_HOST=redis
      # CORREÇÃO 1: Aponta o Node.js para o contêiner do Python na rede Docker
      - GRPC_ENDPOINT=core:50051
    depends_on:
      - core
      - redis
    restart: unless-stopped
    networks:
      - xenosys-network

  # -------------------------------------------------------------------------
  # 2. Core Service (Python)
  # -------------------------------------------------------------------------
  core:
    build:
      context: ./nexus/core
    container_name: xenosys-core
    restart: unless-stopped
    env_file:
      - .env
    environment:
      # Roteamento estrito para os serviços na rede interna do Docker
      - CORTEX_URL=http://xenosys-cortex:8000
      - OPENVIKING_URL=http://xenosys-openviking:8080
      - MCP_MEMORY_URL=http://xenosys-mcp-memory:3000
      - OBSIDIAN_VAULT_PATH=/app/obsidian_vault

      # Binding do gRPC para escutar o Gateway
      - GRPC_HOST=0.0.0.0
      - GRPC_PORT=50051
    ports:
      - "50051:50051"
    depends_on:
      - cortex
      - openviking
      - redis
    networks:
      - xenosys-network
  # -------------------------------------------------------------------------
  # 3. Redis (Message Broker & Cache)
  # -------------------------------------------------------------------------
  redis:
    image: redis:7-alpine
    container_name: xenosys-redis
    ports:
      - "6379:6379"
    command: redis-server --appendonly yes --maxmemory 256mb --maxmemory-policy allkeys-lru
    volumes:
      - redis-data:/data
    restart: unless-stopped
    networks:
      - xenosys-network

  # -------------------------------------------------------------------------
  # 4. OpenViking (Memória Episódica da Volcengine)
  # -------------------------------------------------------------------------
  openviking:
    build: https://github.com/volcengine/OpenViking.git#main
    container_name: xenosys-openviking
    ports:
      - "8081:8080"
    volumes:
      - openviking-data:/data
    restart: unless-stopped
    networks:
      - xenosys-network

  # -------------------------------------------------------------------------
  # 5. Cortex (Memória Semântica da Abbacus Group)
  # -------------------------------------------------------------------------
  cortex:
    build: https://github.com/abbacusgroup/cortex.git#main
    container_name: xenosys-cortex
    ports:
      - "8000:8000"
    volumes:
      - cortex-data:/data
    restart: unless-stopped
    networks:
      - xenosys-network

  # -------------------------------------------------------------------------
  # 6. BrainSys (Graph-based Contextual Memory / L4)
  # -------------------------------------------------------------------------
  mcp-memory:
    image: node:20-alpine
    container_name: xenosys-mcp-memory
    ports:
      - "9000:9000"
    # CORREÇÃO 2: Forçando a porta via ambiente para o servidor MCP
    environment:
      - PORT=9000
    command: npx -y @modelcontextprotocol/server-memory
    volumes:
      - xenosys-l4-data:/app/memory_data
    restart: unless-stopped
    networks:
      - xenosys-network

  # -------------------------------------------------------------------------
  # 7. MCP Server - Obsidian (Long-term Memory / Notes)
  # -------------------------------------------------------------------------
  mcp-obsidian:
    image: node:20-alpine
    container_name: xenosys-mcp-obsidian
    ports:
      - "3001:3001"
    # CORREÇÃO 2: Forçando a porta via ambiente para o servidor MCP
    environment:
      - PORT=3001
    command: npx -y @modelcontextprotocol/server-obsidian --dir /vault
    volumes:
      - obsidian-vault:/vault
    restart: unless-stopped
    networks:
      - xenosys-network

# =============================================================================
# Networks
# =============================================================================
networks:
  xenosys-network:
    driver: bridge
    name: xenosys-network

# =============================================================================
# Volumes
# =============================================================================
volumes:
  redis-data:
    name: xenosys-redis-data
  cortex-data:
    name: xenosys-cortex-data
  openviking-data:
    name: xenosys-openviking-data
  obsidian-vault:
    name: xenosys-obsidian-vault
  xenosys-l4-data:
    name: xenosys-l4-data
